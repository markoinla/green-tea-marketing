---
import AppScreenshot from '../components/AppScreenshot';
import Features from '../components/Features';
import TextBlock from '../components/TextBlock';
import SkillsMockup from '../components/SkillsMockup';
import ScheduledTasksMockup from '../components/ScheduledTasksMockup';
import IntegrationsMockup from '../components/IntegrationsMockup';
import ArtifactsMockup from '../components/ArtifactsMockup';
import SharePublishMockup from '../components/SharePublishMockup';
import ModelsMockup from '../components/ModelsMockup';
import DownloadCTA from '../components/DownloadCTA';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Green Tea | The open source AI workspace</title>
  <meta name="description" content="Green Tea is the open source AI workspace for people who want AI that does real work without handing over their data. Local-first and free. Your notes, your agents, your data." />
  <link rel="icon" type="image/png" href="/icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
  <main>
    <img src="/icon.png" alt="" class="icon" />
    <h1 class="name">Green Tea</h1>
    <p class="tagline">The open source AI workspace.</p>
    <p class="subtagline">Your notes, your agents, your data.</p>
    <a id="download-btn" href="https://github.com/markoinla/green-tea/releases/latest/download/greentea.dmg" class="download">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="7 10 12 15 17 10" />
        <line x1="12" y1="15" x2="12" y2="3" />
      </svg>
      <span id="download-label">Download for macOS</span>
    </a>
    <a id="alt-download" href="#" class="alt-link"></a>
    <div class="social-links">
      <a href="https://github.com/markoinla/green-tea" class="social-btn" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        Star on GitHub
      </a>
      <a href="https://www.linkedin.com/in/stankovicm/" class="social-btn" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>
    </div>
    <script>
      ;(function () {
        var ua = navigator.userAgent
        var isWin = ua.indexOf('Win') !== -1
        var btn = document.getElementById('download-btn')
        var label = document.getElementById('download-label')
        var alt = document.getElementById('alt-download')
        if (isWin) {
          btn.href = 'https://github.com/markoinla/green-tea/releases/latest/download/greentea-setup.exe'
          label.textContent = 'Download for Windows'
          alt.href = 'https://github.com/markoinla/green-tea/releases/latest/download/greentea.dmg'
          alt.textContent = 'Also available for macOS'
        } else {
          alt.href = 'https://github.com/markoinla/green-tea/releases/latest/download/greentea-setup.exe'
          alt.textContent = 'Also available for Windows'
        }
      })()
    </script>

    <div class="screenshot-wrapper">
      <AppScreenshot client:visible />
    </div>

    <Features client:visible />

    <TextBlock
      client:visible
      label="Trust & Control"
      heading="Your data. Your rules."
      body={[
        "Green Tea is open source and runs on your own machine. Your notes, your files, and everything the agent works on stay there. No cloud, no account, and nothing leaves your computer unless you say so.",
        "The source is public, so anyone can check exactly what the app does. Nothing trains on your notes, nothing is locked to a vendor, and it all works offline. Your work is yours.",
      ]}
      buttonText="View the source on GitHub"
      buttonHref="https://github.com/markoinla/green-tea"
    />

    <TextBlock
      client:visible
      label="Extensible"
      heading="A notes app that builds itself."
      body={[
        "Ask Green Tea to build a new skill and it will. Want a tool that turns your Google Analytics into a weekly summary? Tell it. Want an automation that watches competitor pricing and flags changes? Describe it. The agent writes its own tools right inside the app.",
        "You can also connect MCP servers to pull in outside data, APIs, and services. It's the same extensibility developers rely on, but you never touch a terminal. The whole coding world opens up, and you build the workflows you need without writing a line of code.",
      ]}
    >
      <SkillsMockup client:visible />
    </TextBlock>
    <TextBlock
      client:visible
      label="Automation"
      heading="Your AI coworker never sleeps."
      body={[
        "Set up tasks that run on a schedule you choose. Pull a morning briefing from your calendar and email, compile action items after every standup, or follow industry news on the topics you care about. Green Tea handles it without you lifting a finger.",
        "Every task runs on your machine and writes straight into your notes, ready when you sit down to work. No dashboards to check, no tabs to keep open. The information is just there when you need it.",
      ]}
    >
      <ScheduledTasksMockup client:visible />
    </TextBlock>

    <TextBlock
      client:visible
      label="Integrations"
      heading="It works with the tools you already use."
      body={[
        "Connect your Google and Microsoft accounts and the agent can read your calendar, search your inbox, and pull from your Drive, all read-only and on your terms. Now it knows your actual week. It can see the meeting you're prepping for and the email thread behind it.",
        "Instead of guessing, it works from your real schedule, mail, and files. Add an MCP server and it reaches almost any other service you use.",
      ]}
    >
      <IntegrationsMockup client:visible />
    </TextBlock>

    <TextBlock
      client:visible
      label="Artifacts"
      heading="Far more than notes."
      body={[
        "Green Tea is more than a text editor. Ask for an interactive HTML report and watch it render live as the agent writes the code. Sketch a flow on an Excalidraw canvas, edit a spreadsheet in a real data grid, or drop in PDFs and images. Every artifact sits right next to your notes in the same workspace.",
        "And the agent builds them for you. Describe a dashboard of your campaign metrics or a diagram of your architecture and it creates the artifact in place. When you need to hand something off, it turns your notes into Word docs, Excel sheets, and PowerPoint decks.",
      ]}
    >
      <ArtifactsMockup client:visible />
    </TextBlock>

    <TextBlock
      client:visible
      label="Publish"
      heading="Research, write, and publish without leaving your notes."
      body={[
        "Hand a client a URL, not a PDF. Green Tea turns your notes into a report, dashboard, or set of slides and publishes it as a live link they can explore. No separate design, deck, or hosting tool.",
        "The whole loop happens in one place. Research a topic, build the artifact, publish it. The link stays in sync with your notes, so a published page is always current, and you can update or take it down whenever you want.",
      ]}
    >
      <SharePublishMockup client:visible />
    </TextBlock>

    <TextBlock
      client:visible
      label="Models"
      heading="Use any AI model you want."
      body={[
        "Green Tea works with any model. It ships with strong open-source models, so you can start the moment you install it, no API key required.",
        "Want more power or a specific provider? Drop in your Anthropic, OpenAI, or OpenRouter key and you get dozens more models. You pay the provider directly with no markup, you decide which model sees your data, and you can switch whenever you like. You're never locked in.",
      ]}
    >
      <ModelsMockup client:visible />
    </TextBlock>

    <TextBlock
      client:visible
      label="Why Green Tea"
      heading="Most AI tools don't know you. Green Tea does."
      body={[
        "Every session with ChatGPT or Claude starts from scratch. You re-explain your projects, re-upload your docs, and repeat the same context every single time. Meanwhile your notes app can't do any of the actual work.",
        "Green Tea fixes both. It's an open source AI workspace where the agent already knows your work and can run research, write briefs, analyze data, and keep an eye on what matters. I built it because I wanted it. I'm a marketer who codes on the side, and I found the agents developers use for software are just as good at knowledge work. There just wasn't a simple way to use them. Now there is.",
      ]}
      buttonText="Read the docs"
      buttonHref="https://markoinla.github.io/green-tea/"
    />

    <DownloadCTA client:visible />
  </main>
  <footer></footer>
</body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    height: 100%;
    overflow-x: hidden;
  }

  body {
    font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #fafafa;
    color: #1a1a1a;
    min-height: 100vh;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    padding-top: max(6vh, 4rem);
    -webkit-font-smoothing: antialiased;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;
    padding-bottom: 6rem;
    width: 100%;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .icon {
    margin-top: max(8vh, 4rem);
    width: 120px;
    height: 120px;
    border-radius: 26px;
    filter: drop-shadow(0 0 40px rgba(61, 154, 114, 0.12));
    transition: filter 0.4s ease;
  }

  .icon:hover {
    filter: drop-shadow(0 0 60px rgba(61, 154, 114, 0.25));
  }

  .name {
    font-family: 'Outfit', sans-serif;
    font-size: 3.25rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: #111111;
    margin-top: -0.75rem;
  }

  .tagline {
    font-size: 1.25rem;
    font-weight: 400;
    color: #6b7472;
    letter-spacing: 0.01em;
    margin-top: -0.5rem;
  }

  .subtagline {
    font-size: 1rem;
    font-weight: 400;
    color: #99a09e;
    letter-spacing: 0.01em;
    margin-top: -1.25rem;
  }

  .download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    background: rgba(61, 154, 114, 0.08);
    border: 1px solid rgba(61, 154, 114, 0.25);
    border-radius: 8px;
    color: #3d9a72;
    font-family: inherit;
    font-size: 0.9375rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .download:hover {
    background: rgba(61, 154, 114, 0.14);
    border-color: rgba(61, 154, 114, 0.35);
  }

  .alt-link {
    font-size: 0.8125rem;
    color: #999896;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  .alt-link:hover {
    color: #3d9a72;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    color: #999896;
    font-family: inherit;
    font-size: 0.8125rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .social-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.18);
    color: #ccc;
  }

  .screenshot-wrapper {
    width: 100%;
    max-width: 1240px;
    margin-top: 1rem;
  }

  footer {
    position: fixed;
    bottom: 2rem;
    font-size: 0.6875rem;
    color: #c8c6c4;
    letter-spacing: 0.05em;
  }
</style>
